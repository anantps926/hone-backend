# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/hone"

# Redis
REDIS_URL="redis://localhost:6379"

# LLM provider
# - anthropic: uses ANTHROPIC_API_KEY and Claude models
# - gemini: uses GEMINI_API_KEY and Google Gemini models
LLM_PROVIDER="anthropic"

# Anthropic (when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=""

# Gemini (when LLM_PROVIDER=gemini)
GEMINI_API_KEY=""
GEMINI_PLAN_MODEL="gemini-1.5-pro-latest"
GEMINI_CONTENT_MODEL="gemini-1.5-pro-latest"
GEMINI_ASK_MODEL="gemini-1.5-flash-latest"

# YouTube Data API v3
YOUTUBE_API_KEY=""

# Clerk
CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Supabase Storage (audio files — create bucket "hone-audio" or match SUPABASE_STORAGE_BUCKET)
# Dashboard: Storage → New bucket → allow public read for lesson audio URLs
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="hone-audio"

# Auth (dev)
# When true, all routes bypass Clerk auth and use a local dev user.
SKIP_CLERK_AUTH=false

# Cache TTLs (seconds)
PLAN_CACHE_TTL=604800
WORD_CACHE_TTL=2592000
VIDEO_CACHE_TTL=2592000
RATE_LIMIT_WINDOW=3600
RATE_LIMIT_MAX_PLAN=5
RATE_LIMIT_MAX_CONTENT=20
